OPENAI_API_KEY=your-openai-api-key-here
IRIS_PASSWORD=your-iris-password-here
IRIS_USERNAME=superuser
# TODO: Please check the IRIS_BASE_URL
# IRIS Server host on your computer
IRIS_BASE_URL=http://localhost:52773/csp/healthshare/fhir/fhir/r4
# Docker
# IRIS_BASE_URL=http://host.docker.internal:52773/csp/healthshare/fhir/fhir/r4

# Can be either a single JSON bundle file or a directory containing *.json bundles.
# The fhir data in data foler come from the repository: https://github.com/intersystems/samples-FHIR-resource-repository
FHIR_FALLBACK_PATH=data

# Keep false for users who want to connect to their own IRIS server without
# writing sample data into it. Set true only for local demos where loading the
# bundled sample data is desired.
LOAD_SAMPLE_BUNDLE=false
